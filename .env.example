# ─────────────────────────────────────────────────────────────
# Root environment example. Copy to `.env` for docker-compose,
# and see server/.env.example / web/.env.example for app-level vars.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (used by docker-compose)
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm

# Exposed ports
API_PORT=4000
WEB_PORT=5173
POSTGRES_PORT=5432
