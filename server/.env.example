# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database (local dev — matches docker-compose default)
DATABASE_URL=postgresql://crm:crm_password@localhost:5432/crm?schema=public

# Auth — generate strong secrets in production, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# AI provider: mock | anthropic | openai
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
