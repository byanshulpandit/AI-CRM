// AI-CRM Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Role {
  ADMIN
  SALES_MANAGER
  EMPLOYEE
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
  CHURNED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EVENT
  SOCIAL
  EMAIL_CAMPAIGN
  OTHER
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STATUS_CHANGE
  FILE
  DEAL_UPDATE
  TASK
  AI_INSIGHT
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum InsightKind {
  SUMMARY
  FOLLOWUP
  NEXT_STEP
}

// ─────────────────────────────── Models ──────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role     @default(EMPLOYEE)
  avatarUrl    String?
  title        String?
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  ownedCustomers  Customer[]     @relation("CustomerOwner")
  assignedLeads   Lead[]         @relation("LeadAssignee")
  ownedDeals      Deal[]         @relation("DealOwner")
  tasks           Task[]         @relation("TaskAssignee")
  activities      Activity[]
  notes           Note[]
  emails          EmailLog[]
  uploads         Attachment[]
  notifications   Notification[]

  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  status    CustomerStatus @default(LEAD)
  tags      String[]       @default([])
  website   String?
  address   String?
  city      String?
  country   String?
  notes     String?
  avatarUrl String?
  ownerId   String
  owner     User           @relation("CustomerOwner", fields: [ownerId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  leads       Lead[]
  deals       Deal[]
  activities  Activity[]
  customerNotes Note[]
  emails      EmailLog[]
  attachments Attachment[]
  tasks       Task[]
  insights    AiInsight[]

  @@index([ownerId])
  @@index([status])
  @@index([name])
}

model Lead {
  id           String     @id @default(cuid())
  title        String
  status       LeadStatus @default(NEW)
  source       LeadSource @default(WEBSITE)
  value        Decimal    @default(0) @db.Decimal(12, 2)
  contactName  String?
  contactEmail String?
  contactPhone String?
  score        Int?
  scoreRating  String?
  scoreReason  String?
  scoredAt     DateTime?
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?      @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  activities Activity[]

  @@index([status])
  @@index([assignedToId])
  @@index([customerId])
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stages Stage[]
}

model Stage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  color      String   @default("#6366f1")
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  deals Deal[]

  @@unique([pipelineId, order])
  @@index([pipelineId])
}

model Deal {
  id                 String     @id @default(cuid())
  title              String
  value              Decimal    @default(0) @db.Decimal(12, 2)
  currency           String     @default("USD")
  status             DealStatus @default(OPEN)
  probability        Int        @default(50)
  position           Int        @default(0)
  expectedCloseDate  DateTime?
  closedAt           DateTime?
  stageId            String
  stage              Stage      @relation(fields: [stageId], references: [id])
  customerId         String
  customer           Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ownerId            String
  owner              User       @relation("DealOwner", fields: [ownerId], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  activities  Activity[]
  tasks       Task[]
  attachments Attachment[]

  @@index([stageId])
  @@index([customerId])
  @@index([ownerId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  assigneeId  String
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  dealId      String?
  deal        Deal?      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  summary    String
  metadata   Json?
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dealId     String?
  deal       Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@index([customerId])
  @@index([dealId])
  @@index([userId])
  @@index([createdAt])
}

model Note {
  id         String   @id @default(cuid())
  body       String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model EmailLog {
  id         String         @id @default(cuid())
  subject    String
  body       String
  direction  EmailDirection
  fromAddr   String
  toAddr     String
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAt     DateTime       @default(now())

  @@index([customerId])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dealId       String?
  deal         Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([customerId])
  @@index([dealId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String?
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
}

model AiInsight {
  id         String      @id @default(cuid())
  kind       InsightKind
  content    String
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([customerId])
}
